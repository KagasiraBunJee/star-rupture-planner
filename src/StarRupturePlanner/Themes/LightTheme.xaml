<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FA"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBrushSoft" Color="#F3F6F8"/>
    <SolidColorBrush x:Key="CenterBackgroundBrush" Color="#E9EEF3"/>
    <SolidColorBrush x:Key="CanvasBrush" Color="#F8FAFB"/>
    <SolidColorBrush x:Key="CanvasDotBrush" Color="#D6DDE1"/>
    <SolidColorBrush x:Key="CanvasMajorDotBrush" Color="#B9C4CA"/>

    <!-- Inner cards -->
    <SolidColorBrush x:Key="MutedPanelBrush" Color="#EEF2F5"/>
    <SolidColorBrush x:Key="MutedBorderBrush" Color="#C7D1D8"/>

    <!-- Controls -->
    <SolidColorBrush x:Key="ControlBrush" Color="#F6F8FA"/>
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#EAF2FA"/>
    <SolidColorBrush x:Key="GraphiteLineBrush" Color="#C7D1D8"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="StarBlueBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="ReactorOrangeBrush" Color="#FF8A00"/>
    <SolidColorBrush x:Key="SignalGreenBrush" Color="#3FB91F"/>

    <!-- Text -->
    <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#14202A"/>
    <SolidColorBrush x:Key="ThemeSecondaryForegroundBrush" Color="#54636E"/>
    <SolidColorBrush x:Key="LeftListForegroundBrush" Color="#14202A"/>
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#45535B"/>
</ResourceDictionary>
