<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:StarRupturePlanner.Converters"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Fonts (theme-independent; LeftList* are overridden at runtime from settings) -->
    <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="LeftListFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
    <sys:Double x:Key="LeftListFontSize">12</sys:Double>
    <converters:PlaceholderImageSourceConverter x:Key="PlaceholderImageSourceConverter"/>

    <!-- Category accent brushes (machine card top bar) -->
    <SolidColorBrush x:Key="AccentExtractionBrush" Color="#C8893B"/>
    <SolidColorBrush x:Key="AccentProcessingBrush" Color="#3FB6A8"/>
    <SolidColorBrush x:Key="AccentTemperatureBrush" Color="#FF7A3C"/>
    <SolidColorBrush x:Key="AccentCraftingBrush" Color="#9B6BE0"/>
    <SolidColorBrush x:Key="AccentDefaultBrush" Color="#5A7B8C"/>

    <!-- Alert severity brushes (bottleneck chips) -->
    <SolidColorBrush x:Key="AlertCriticalBrush" Color="#FF4848"/>
    <SolidColorBrush x:Key="AlertWarningBrush" Color="#FF8A00"/>
    <SolidColorBrush x:Key="AlertInfoBrush" Color="#0A84FF"/>

    <!-- Custom window caption (title bar) buttons -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="2,0,0,0"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#E81123"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryForegroundBrush}"/>
        <Setter Property="Padding" Value="0,10,0,4"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Padding" Value="13,5"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource StarBlueBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton Grid.ColumnSpan="2"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Chrome"
                                            Background="{DynamicResource ControlBrush}"
                                            BorderBrush="{DynamicResource GraphiteLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Grid.Column="0"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                        <TextBlock Grid.Column="1"
                                   Text="▾"
                                   Margin="8,0,11,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"
                                   IsHitTestVisible="False"/>
                        <Popup Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide"
                               MinWidth="{TemplateBinding ActualWidth}">
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource GraphiteLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MaxHeight="280"
                                    Margin="0,2,0,0">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemChrome"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="5"
                            Margin="3,1">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource PanelBrushSoft}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemChrome"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SuggestionListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="6,0,6,4"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource ListItemHoverBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ItemChrome" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsHeader}" Value="True">
                            <Setter TargetName="ItemChrome" Property="Padding" Value="8,4"/>
                            <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="Transparent"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                <Setter Property="IsHitTestVisible" Value="False"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Margin" Value="6,6,6,0"/>
                <Setter Property="Padding" Value="8,4"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="SuggestionRecipeTemplate">
        <Grid>
            <TextBlock x:Name="HeaderText"
                       Text="{Binding Header}"
                       Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Visibility="Collapsed"/>
            <Border x:Name="SuggestionCard"
                    BorderBrush="Transparent"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34"
                            Height="34"
                            Background="{DynamicResource NodeCardImageBrush}"
                            BorderBrush="{DynamicResource NodeCardImageBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Image Width="28"
                               Height="28"
                               Source="{Binding ImageUrl, Converter={StaticResource PlaceholderImageSourceConverter}}"
                               Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{DynamicResource ThemeForegroundBrush}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SuggestedMaterialName}"
                                       Foreground="{DynamicResource StarBlueBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SuggestedMaterialRateText}"
                                       Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"
                                       FontSize="11"
                                       Margin="8,0,0,0"/>
                        </Grid>
                        <TextBlock Text="{Binding Detail}"
                                   Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"
                                   FontSize="10.5"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                <Setter TargetName="HeaderText" Property="Visibility" Value="Visible"/>
                <Setter TargetName="SuggestionCard" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding HasShortageRisk}" Value="True">
                <Setter TargetName="SuggestionCard" Property="BorderBrush" Value="#FF6B6B"/>
                <Setter TargetName="SuggestionCard" Property="BorderThickness" Value="2"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0" IsItemsHost="True" Margin="0,0,0,6" Background="Transparent"/>
                        <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryForegroundBrush}"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabChrome"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}"
                            Margin="0,0,4,0">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabChrome" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource StarBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SchemeDeleteButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="Foreground" Value="#FF4848"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="ToolTip" Value="Delete scheme"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#2A1014"/>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#FF6B6B"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="SchemeItemTemplate">
        <Border x:Name="Card" Padding="10,8" Margin="0,0,0,4" Background="{DynamicResource MutedPanelBrush}" BorderBrush="{DynamicResource MutedBorderBrush}" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               Foreground="{DynamicResource LeftListForegroundBrush}"
                               FontFamily="{DynamicResource LeftListFontFamily}"
                               FontSize="{DynamicResource LeftListFontSize}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding OutputStatusText}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontFamily="{DynamicResource LeftListFontFamily}" FontSize="11" Margin="0,4,0,0"/>
                    <ItemsControl ItemsSource="{Binding Outputs}" Margin="0,7,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource NodeCardImageBrush}" BorderBrush="{DynamicResource NodeCardImageBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="5,3" Margin="0,0,5,5" ToolTip="{Binding DisplayName}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="18" Height="18" Source="{Binding ImageUrl, Converter={StaticResource PlaceholderImageSourceConverter}}" Stretch="Uniform" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding RateText}" Foreground="{DynamicResource StarBlueBrush}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource SchemeDeleteButtonStyle}"
                        Tag="DeleteScheme"
                        VerticalAlignment="Top"
                        Content="&#xE74D;"/>
            </Grid>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ListItemHoverBorderBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                <Setter TargetName="Card" Property="BorderThickness" Value="1.5"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="ResourceItemTemplate">
        <Border x:Name="Card" Padding="9" Margin="0,0,4,6" Background="{DynamicResource MutedPanelBrush}" BorderBrush="{DynamicResource MutedBorderBrush}" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" Background="{DynamicResource NodeCardImageBrush}" BorderBrush="{DynamicResource NodeCardImageBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Image Width="28" Height="28" Source="{Binding ResourceImageUrl, Converter={StaticResource PlaceholderImageSourceConverter}}" Stretch="Uniform"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="9,0,0,0">
                    <TextBlock Text="{Binding ResourceName}" Foreground="{DynamicResource LeftListForegroundBrush}" FontFamily="{DynamicResource LeftListFontFamily}" FontSize="{DynamicResource LeftListFontSize}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Image Width="18" Height="18" Source="{Binding MachineImageUrl, Converter={StaticResource PlaceholderImageSourceConverter}}" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding MachineName}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontFamily="{DynamicResource LeftListFontFamily}" FontSize="{DynamicResource LeftListFontSize}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SpeedPerMinute, StringFormat={}{0:g}/min}" Foreground="{DynamicResource StarBlueBrush}" FontFamily="{DynamicResource LeftListFontFamily}" FontSize="{DynamicResource LeftListFontSize}" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ListItemHoverBorderBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                <Setter TargetName="Card" Property="BorderThickness" Value="1.5"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <DataTemplate x:Key="MachineItemTemplate">
        <Border x:Name="Card" Padding="9" Margin="0,0,4,6" Background="{DynamicResource MutedPanelBrush}" BorderBrush="{DynamicResource MutedBorderBrush}" BorderThickness="1" CornerRadius="7" HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" Background="{DynamicResource NodeCardImageBrush}" BorderBrush="{DynamicResource NodeCardImageBorderBrush}" BorderThickness="1" CornerRadius="6">
                    <Image Width="28" Height="28" Source="{Binding ImageUrl, Converter={StaticResource PlaceholderImageSourceConverter}}" Stretch="Uniform"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource LeftListForegroundBrush}" FontFamily="{DynamicResource LeftListFontFamily}" FontSize="{DynamicResource LeftListFontSize}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Margin="9,0,0,0"/>
            </Grid>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource ListItemHoverBorderBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                <Setter TargetName="Card" Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource StarBlueBrush}"/>
                <Setter TargetName="Card" Property="BorderThickness" Value="1.5"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ToolTip (Windows default renders a light box) -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GraphiteLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dark scrollbars (Windows default renders light) -->
    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Thumb" CornerRadius="4" Background="{DynamicResource ScrollThumbBrush}" Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
