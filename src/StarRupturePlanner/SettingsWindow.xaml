<Window x:Class="StarRupturePlanner.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="520"
        Height="430"
        MinWidth="500"
        MinHeight="390"
        WindowStartupLocation="CenterOwner"
        FontFamily="{DynamicResource AppFontFamily}"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="Padding" Value="0,8,0,3"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" IsDefault="True" Click="Save_Click"/>
            <Button Content="Cancel" IsCancel="True"/>
        </StackPanel>

        <TabControl>
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Theme" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ThemePicker" DisplayMemberPath="Label" SelectedValuePath="Value" Margin="0,0,0,12"/>

                        <TextBlock Text="Canvas card font" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Family"/>
                                <ComboBox x:Name="CanvasFontFamilyPicker"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <Label Content="Size"/>
                                <TextBox x:Name="CanvasFontSizeBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Color"/>
                                <TextBox x:Name="CanvasFontColorBox"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Left bar list font" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Family"/>
                                <ComboBox x:Name="LeftFontFamilyPicker"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <Label Content="Size"/>
                                <TextBox x:Name="LeftFontSizeBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Color"/>
                                <TextBox x:Name="LeftFontColorBox"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="In game">
                <StackPanel Margin="12">
                    <TextBlock Text="Rail tier availability is derived from scheme corporation levels in the inspector."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
