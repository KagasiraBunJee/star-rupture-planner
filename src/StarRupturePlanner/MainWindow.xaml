<Window x:Class="StarRupturePlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StarRupturePlanner.Controls"
        xmlns:services="clr-namespace:StarRupturePlanner.Services"
        xmlns:views="clr-namespace:StarRupturePlanner.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Ui.App.Title}"
        Height="900"
        Width="1500"
        MinHeight="760"
        MinWidth="1180"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="{DynamicResource AppFontFamily}"
        KeyDown="Window_KeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="70"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid x:Name="RootGrid" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="104"/>
        </Grid.RowDefinitions>

        <views:CommandBarView x:Name="CommandBar" Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="12,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <views:ToolboxView x:Name="ToolboxPanel" Grid.Column="0"/>

            <views:CanvasView x:Name="CanvasPanel" Grid.Column="1"/>

            <views:InspectorView x:Name="InspectorPanel" Grid.Column="2"/>
        </Grid>

        <views:AlertsBarView x:Name="AlertsBar" Grid.Row="2"/>

        <!-- Full-window loading overlay shown while the catalog (resources/machines) loads. -->
        <Grid x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="100"
              Background="#D6080C11" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="60" Height="60" HorizontalAlignment="Center">
                    <Ellipse Width="60" Height="60" Stroke="{DynamicResource GraphiteLineBrush}" StrokeThickness="6" Opacity="0.5"/>
                    <Ellipse Width="60" Height="60" Stroke="{DynamicResource StarBlueBrush}" StrokeThickness="6"
                             StrokeDashArray="8,24" StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="LoadingSpinnerRotate" Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
                <TextBlock Text="Loading…" Foreground="{DynamicResource ThemeForegroundBrush}"
                           FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,18,0,0"/>
            </StackPanel>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="LoadingSpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:1"
                                             RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>
