<Window x:Class="StarRupturePlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StarRupturePlanner.Controls"
        xmlns:services="clr-namespace:StarRupturePlanner.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Ui.App.Title}"
        Height="900"
        Width="1500"
        MinHeight="760"
        MinWidth="1180"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="{DynamicResource AppFontFamily}"
        KeyDown="Window_KeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="70"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid x:Name="RootGrid" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="104"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopCommandBar" Grid.Row="0" Margin="12,10,12,6" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="1" CornerRadius="12">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✦" Foreground="{DynamicResource StarBlueBrush}" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource Ui.App.Name}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border x:Name="AppChannelBadge" Background="{DynamicResource StarBlueBrush}" CornerRadius="5" Padding="7,2" Margin="9,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="AppChannelText" Text="ALPHA" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="AppVersionText" Text="{DynamicResource Ui.App.Subtitle}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" shell:WindowChrome.IsHitTestVisibleInChrome="True" Height="38" MaxWidth="560" MinWidth="180" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="20,0" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="1" CornerRadius="8" Padding="11,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⌕" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="21" VerticalAlignment="Center" Margin="0,0,9,1"/>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="TopSearchBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MinHeight="0"
                                     Padding="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TopSearchBox_TextChanged"
                                     Text="{Binding Toolbox.FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock x:Name="TopSearchPlaceholder"
                                       Text="{DynamicResource Ui.Search.Placeholder}"
                                       Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                            </TextBlock>
                        </Grid>
                        <Border Grid.Column="2" VerticalAlignment="Center" Height="22" BorderBrush="{DynamicResource MutedBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="8,0">
                            <TextBlock Text="Ctrl+K" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" shell:WindowChrome.IsHitTestVisibleInChrome="True" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="NewScheme_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="＋" Margin="0,0,7,0"/><TextBlock Text="{DynamicResource Ui.Command.New}"/></StackPanel>
                    </Button>
                    <Button Click="ChooseFolder_Click" Margin="0,0,8,0" ToolTip="Choose scheme folder">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="▱" Margin="0,0,7,0"/><TextBlock Text="{DynamicResource Ui.Command.Open}"/></StackPanel>
                    </Button>
                    <Button Click="SaveScheme_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="▣" Margin="0,0,7,0"/><TextBlock Text="{DynamicResource Ui.Command.Save}"/></StackPanel>
                    </Button>
                    <Button IsEnabled="False" Margin="0,0,8,0" ToolTip="Export (coming soon)">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="⇩" Margin="0,0,7,0"/><TextBlock Text="{DynamicResource Ui.Command.Export}"/><TextBlock Text="▾" Margin="6,0,0,0"/></StackPanel>
                    </Button>
                    <Button IsEnabled="False" Margin="0,0,8,0" ToolTip="Share (coming soon)">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="↗" Margin="0,0,7,0"/><TextBlock Text="{DynamicResource Ui.Command.Share}"/></StackPanel>
                    </Button>
                    <Button Click="Settings_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="⚙" Margin="0,0,7,0"/><TextBlock Text="{DynamicResource Ui.Command.Settings}"/></StackPanel>
                    </Button>
                    <Border Width="1" Background="{DynamicResource GraphiteLineBrush}" Margin="12,6"/>
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}" Click="MinimizeButton_Click" Content="&#xE921;" ToolTip="Minimize"/>
                    <Button x:Name="MaxRestoreButton" Style="{StaticResource CaptionButton}" Click="MaxRestoreButton_Click" Content="&#xE922;" ToolTip="Maximize"/>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionCloseButton}" Click="CloseButton_Click" Content="&#xE8BB;" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LeftPanel" Grid.Column="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Ui.Nav.Navigation}" Style="{StaticResource PanelTitle}"/>
                        <StackPanel>
                            <Border Background="{DynamicResource NavActiveBackgroundBrush}" BorderBrush="{DynamicResource StarBlueBrush}" BorderThickness="3,0,0,0" CornerRadius="7" Padding="12,9" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▤" Foreground="{DynamicResource StarBlueBrush}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource Ui.Nav.Production}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Ui.Nav.Toolbox}" Style="{StaticResource PanelTitle}" Margin="0,12,0,8"/>
                        <TextBox x:Name="ToolboxFilterBox" Text="{Binding Toolbox.FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource MutedPanelBrush}" BorderBrush="{DynamicResource MutedBorderBrush}" BorderThickness="1" CornerRadius="9" Padding="11" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Ui.Plan.Current}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                            <TextBlock Text="{Binding Scheme.Name}" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse Width="7" Height="7" Fill="{DynamicResource SignalGreenBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding LastSavedText}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SchemeFolderPath}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <TabControl x:Name="ToolboxTabs">
                        <TabItem Header="{DynamicResource Ui.Tab.Schemes}">
                            <ListBox x:Name="SchemesList"
                                     Background="{DynamicResource CanvasBrush}"
                                     ItemsSource="{Binding Toolbox.Schemes}"
                                     ItemTemplate="{StaticResource SchemeItemTemplate}"
                                     PreviewMouseLeftButtonDown="SchemesList_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="SchemesList_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="SchemesList_PreviewMouseLeftButtonUp"
                                     SelectionChanged="SchemesList_SelectionChanged"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </TabItem>
                        <TabItem Header="{DynamicResource Ui.Tab.Resources}">
                            <ListBox x:Name="ResourcesList"
                                     Background="{DynamicResource CanvasBrush}"
                                     ItemsSource="{Binding Toolbox.Resources}"
                                     ItemTemplate="{StaticResource ResourceItemTemplate}"
                                     PreviewMouseLeftButtonDown="ResourcesList_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ResourcesList_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="ResourcesList_PreviewMouseLeftButtonUp"
                                     MouseDoubleClick="ResourcesList_MouseDoubleClick"
                                     ScrollViewer.VerticalScrollBarVisibility="Visible"/>
                        </TabItem>
                        <TabItem Header="{DynamicResource Ui.Tab.Machines}">
                            <ListBox x:Name="MachinesList"
                                     Background="{DynamicResource CanvasBrush}"
                                     ItemsSource="{Binding Toolbox.Machines}"
                                     ItemTemplate="{StaticResource MachineItemTemplate}"
                                     PreviewMouseLeftButtonDown="MachinesList_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="MachinesList_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="MachinesList_PreviewMouseLeftButtonUp"
                                     MouseDoubleClick="MachinesList_MouseDoubleClick"
                                     ScrollViewer.VerticalScrollBarVisibility="Visible"/>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>

            <Grid x:Name="CenterPanel" Grid.Column="1" Margin="10,0" Background="{DynamicResource CenterBackgroundBrush}">
                <Border x:Name="CanvasFrame" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="1" Background="{DynamicResource CanvasBrush}" CornerRadius="12">
                    <!-- Canvas-level input is handled here, the common ancestor of the grid and the
                         content layer, so pan/zoom/select work whether the cursor is over empty grid
                         or over a node. Node/edge clicks mark the event handled so they take priority. -->
                    <Grid x:Name="CanvasViewport" ClipToBounds="True"
                          AllowDrop="True"
                          DragOver="PlannerCanvas_DragOver"
                          Drop="PlannerCanvas_Drop"
                          MouseDown="PlannerCanvas_MouseDown"
                          MouseLeftButtonDown="PlannerCanvas_MouseLeftButtonDown"
                          MouseLeftButtonUp="PlannerCanvas_MouseLeftButtonUp"
                          MouseMove="PlannerCanvas_MouseMove"
                          MouseRightButtonDown="PlannerCanvas_MouseRightButtonDown"
                          MouseRightButtonUp="PlannerCanvas_MouseRightButtonUp"
                          MouseUp="PlannerCanvas_MouseUp"
                          MouseWheel="PlannerCanvas_MouseWheel">
                        <!-- Screen-space infinite grid (not transformed). Empty-area clicks land on
                             this layer (it provides the canvas backdrop); events bubble to the viewport. -->
                        <controls:DottedGridCanvas x:Name="GridInputLayer"
                                                    GridSize="24"
                                                    Background="{DynamicResource CanvasBrush}"
                                                    DotBrush="{DynamicResource CanvasDotBrush}"
                                                    MajorDotBrush="{DynamicResource CanvasMajorDotBrush}"
                                                    OffsetX="{Binding X, ElementName=CanvasTranslate}"
                                                    OffsetY="{Binding Y, ElementName=CanvasTranslate}"
                                                    Zoom="{Binding ScaleX, ElementName=CanvasScale}"/>

                        <!-- Transformed content layer (transparent so empty areas fall through to the
                             grid/input layer). Nodes may live at any coordinate, including negative. -->
                        <Canvas x:Name="PlannerCanvas"
                                Width="200000"
                                Height="200000"
                                Background="{x:Null}">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                        <Popup x:Name="SuggestionPopup"
                               AllowsTransparency="True"
                               Placement="Relative"
                               PlacementTarget="{Binding ElementName=CanvasFrame}"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border x:Name="SuggestionPopupChrome"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource StarBlueBrush}"
                                    BorderThickness="1"
                                    Width="330"
                                    MaxHeight="360"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True"
                                    SizeChanged="SuggestionPopupChrome_SizeChanged">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Ui.Popup.ConnectCompatible}" FontWeight="SemiBold" Margin="12" Foreground="{DynamicResource ThemeForegroundBrush}"/>
                                    <ListBox x:Name="SuggestionList"
                                             ItemTemplate="{StaticResource SuggestionRecipeTemplate}"
                                             ItemContainerStyle="{StaticResource SuggestionListBoxItemStyle}"
                                             SelectionChanged="SuggestionList_SelectionChanged"
                                             Background="Transparent"
                                             BorderThickness="0"/>
                                </DockPanel>
                            </Border>
                        </Popup>

                        <Border x:Name="SurplusPillsBar"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0"
                                MaxWidth="900"
                                Panel.ZIndex="20"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource GraphiteLineBrush}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="10,6"
                                Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{DynamicResource Ui.Label.Surplus}"
                                           Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="SurplusPills_PreviewMouseWheel">
                                    <StackPanel x:Name="SurplusPills" Orientation="Horizontal"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="RightPanel" Grid.Column="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource MutedPanelBrush}" BorderBrush="{DynamicResource MutedBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="64" Height="64" Background="{DynamicResource NodeCardImageBrush}" BorderBrush="{DynamicResource NodeCardImageBorderBrush}" BorderThickness="1" CornerRadius="9">
                                    <Image x:Name="InspectorImage" Width="56" Height="56" Source="{x:Static services:BlueprintPlaceholderIcon.Image}" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="InspectorTitle" Text="{DynamicResource Ui.Inspector.NoSelection}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource ThemeForegroundBrush}" TextWrapping="Wrap"/>
                                    <StackPanel x:Name="InspectorStatusPanel" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Ellipse Width="10" Height="10" Fill="{DynamicResource SignalGreenBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="{DynamicResource Ui.Inspector.Operational}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="{DynamicResource Ui.Inspector.Title}" Style="{StaticResource PanelTitle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border x:Name="InspectorTabDetails" Tag="Details" Background="Transparent" Cursor="Hand" BorderBrush="{DynamicResource StarBlueBrush}" BorderThickness="0,0,0,2" Padding="10,0,10,7" MouseLeftButtonUp="InspectorTab_Click">
                                <TextBlock x:Name="InspectorTabDetailsText" Text="{DynamicResource Ui.Inspector.Details}" Foreground="{DynamicResource StarBlueBrush}" FontWeight="SemiBold"/>
                            </Border>
                            <Border x:Name="InspectorTabStatistics" Tag="Statistics" Background="Transparent" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="10,0,10,7" Margin="8,0,0,0" MouseLeftButtonUp="InspectorTab_Click">
                                <TextBlock x:Name="InspectorTabStatisticsText" Text="{DynamicResource Ui.Inspector.Statistics}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"/>
                            </Border>
                            <Border x:Name="InspectorTabModifications" Tag="Modifications" Background="Transparent" Cursor="Hand" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="10,0,10,7" Margin="8,0,0,0" MouseLeftButtonUp="InspectorTab_Click">
                                <TextBlock x:Name="InspectorTabModificationsText" Text="{DynamicResource Ui.Inspector.Modifications}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="SchemeSettingsPanel" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource Ui.Inspector.SchemeSettings}" Style="{StaticResource PanelTitle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{DynamicResource Ui.Inspector.Corporations}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel x:Name="CorporationSettingsStack"/>

                            <Border Height="1" Background="{DynamicResource MutedBorderBrush}" Margin="0,14,0,12"/>
                            <TextBlock Text="{DynamicResource Ui.Inspector.RailTier}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel x:Name="RailTierSettingsStack"/>
                        </StackPanel>

                        <StackPanel x:Name="NodeInspectorPanel">
                            <StackPanel x:Name="InspectorDetailsPanel">
                                <Label Content="{DynamicResource Ui.Inspector.Output}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TargetOutputBox" Grid.Column="0" TextChanged="TargetOutputBox_TextChanged"/>
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <Button x:Name="OutputStepUp" Content="▲" Padding="6,0" MinHeight="15" FontSize="9" Click="OutputStepUp_Click"/>
                                        <Button x:Name="OutputStepDown" Content="▼" Padding="6,0" MinHeight="15" FontSize="9" Margin="0,2,0,0" Click="OutputStepDown_Click"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="🔒" IsEnabled="False" Margin="6,0,0,0" ToolTip="Lock count (coming soon)"/>
                                </Grid>

                                <Label Content="{DynamicResource Ui.Inspector.Recipe}"/>
                                <Grid>
                                    <TextBox x:Name="InspectorRecipeSearchBox"
                                             PreviewMouseLeftButtonDown="InspectorRecipeSearchBox_PreviewMouseLeftButtonDown"
                                             GotKeyboardFocus="InspectorRecipeSearchBox_GotKeyboardFocus"
                                             LostKeyboardFocus="InspectorRecipePicker_LostKeyboardFocus"
                                             TextChanged="InspectorRecipeSearchBox_TextChanged"/>
                                    <Popup x:Name="InspectorRecipePopup"
                                           PlacementTarget="{Binding ElementName=InspectorRecipeSearchBox}"
                                           Placement="Bottom"
                                           Width="{Binding ActualWidth, ElementName=InspectorRecipeSearchBox}"
                                           StaysOpen="True"
                                           Closed="InspectorRecipePopup_Closed">
                                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource StarBlueBrush}" BorderThickness="1" MaxHeight="320" CornerRadius="8">
                                            <ListBox x:Name="InspectorRecipeList"
                                                     DisplayMemberPath="InspectorDisplayName"
                                                     SelectionChanged="InspectorRecipeList_SelectionChanged"
                                                     LostKeyboardFocus="InspectorRecipePicker_LostKeyboardFocus"
                                                     BorderThickness="0"/>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <StackPanel Margin="0,12,0,0">
                                    <Button x:Name="OpenBlueprintSourceButton"
                                            Content="Open scheme"
                                            Visibility="Collapsed"
                                            Click="OpenBlueprintSourceButton_Click"/>
                                    <CheckBox x:Name="OnlyOutputCheckBox"
                                              Content="Only output"
                                              Margin="0,8,0,0"
                                              Checked="OnlyOutputCheckBox_Changed"
                                              Unchecked="OnlyOutputCheckBox_Changed"/>
                                    <CheckBox x:Name="SchemeOutputCheckBox"
                                              Content="Is Scheme output"
                                              Margin="0,8,0,0"
                                              Checked="SchemeOutputCheckBox_Changed"
                                              Unchecked="SchemeOutputCheckBox_Changed"/>
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource MutedBorderBrush}" Margin="0,14,0,4"/>
                                <StackPanel x:Name="InspectorMetricsStack" Margin="0,4,0,0"/>

                                <Label Content="{DynamicResource Ui.Inspector.Priority}"/>
                                <ComboBox x:Name="PriorityBox"
                                          SelectionChanged="PriorityBox_SelectionChanged">
                                    <ComboBoxItem Content="{DynamicResource Ui.Priority.High}" Tag="High"/>
                                    <ComboBoxItem Content="{DynamicResource Ui.Priority.Mid}" Tag="Mid"/>
                                    <ComboBoxItem Content="{DynamicResource Ui.Priority.Low}" Tag="Low"/>
                                </ComboBox>

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" IsEnabled="False" Margin="0,0,4,0" ToolTip="Lock count (coming soon)">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="🔒" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Ui.Inspector.LockCount}"/></StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" IsEnabled="False" Margin="4,0,0,0" Background="{DynamicResource StarBlueBrush}" ToolTip="Auto-optimize (coming soon)">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="▦" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Ui.Inspector.Optimize}"/></StackPanel>
                                    </Button>
                                </Grid>

                                <TextBlock x:Name="InspectorReadOnly" TextWrapping="Wrap" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="12" Margin="0,10,0,0"/>
                            </StackPanel>

                            <StackPanel x:Name="InspectorStatisticsPanel" Visibility="Collapsed">
                                <Label Content="{DynamicResource Ui.Inspector.InputRequirements}"/>
                                <ItemsControl x:Name="InspectorInputs"/>
                            </StackPanel>

                            <StackPanel x:Name="InspectorModificationsPanel" Visibility="Collapsed">
                                <Label Content="{DynamicResource Ui.Inspector.UnlockRequirements}"/>
                                <ItemsControl x:Name="InspectorUnlocks"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ConnectionInspectorPanel">
                            <Label Content="{DynamicResource Ui.Inspector.SelectedConnection}"/>
                            <TextBlock x:Name="ConnectionReadOnly" TextWrapping="Wrap" Foreground="{DynamicResource ThemeForegroundBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="12,8,12,10" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource GraphiteLineBrush}" BorderThickness="1" CornerRadius="12" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Ui.Alerts.Title}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock x:Name="StatusText" Text="{Binding Status}" Foreground="{DynamicResource StatusForegroundBrush}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="620"/>
                    </StackPanel>
                    <ScrollViewer x:Name="AlertsScroller"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Margin="0,7,0,0"
                                  PreviewMouseWheel="AlertsScroller_PreviewMouseWheel">
                        <StackPanel x:Name="AlertsChips" Orientation="Horizontal"/>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="14,0" MaxWidth="260">
                        <TextBlock Text="Scheme Outputs" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                        <TextBlock x:Name="MetricSchemeOutputs" Text="No scheme outputs marked" FontWeight="SemiBold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel Margin="14,0">
                        <TextBlock Text="{DynamicResource Ui.Metric.TotalPower}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                        <TextBlock x:Name="MetricPower" Text="-" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="14,0">
                        <TextBlock Text="{DynamicResource Ui.Metric.Temperature}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                        <TextBlock x:Name="MetricTemperature" Text="-" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="14,0">
                        <TextBlock Text="{DynamicResource Ui.Metric.Efficiency}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                        <TextBlock Text="—" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="14,0">
                        <TextBlock Text="{DynamicResource Ui.Metric.Machines}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                        <TextBlock x:Name="MetricMachines" Text="0" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Width="1" Background="{DynamicResource MutedBorderBrush}" Margin="8,4" VerticalAlignment="Stretch"/>
                    <StackPanel Margin="14,0,4,0">
                        <TextBlock Text="{DynamicResource Ui.Metric.Canvas}" Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" FontSize="11"/>
                        <TextBlock x:Name="ZoomText" Text="100%" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Content="⟲" FontSize="15" Width="34" MinHeight="30" Padding="0" Margin="6,0,0,0" VerticalAlignment="Center" Click="ResetZoom_Click" ToolTip="Reset zoom to 100%"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
